# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# FIREBASE CONFIGURATION (FOR MANUAL PRIVATE INSTANCE PERSISTENCE)
# If provided, the server will persist surveys and responses directly to your Firestore database.
# If these variables are omitted, the server automatically defaults back to high-performance disk-based data.json persistence.
FIREBASE_API_KEY=""
FIREBASE_AUTH_DOMAIN=""
FIREBASE_PROJECT_ID=""
FIREBASE_STORAGE_BUCKET=""
FIREBASE_MESSAGING_SENDER_ID=""
FIREBASE_APP_ID=""
FIREBASE_DATABASE_ID=""

# SUPABASE CONFIGURATION (FOR GENERAL REAL persistence AND PRODUCTION SCALING)
# Provide these to use Supabase PostgreSQL to store survey configurations and responses.
SUPABASE_URL=""
SUPABASE_KEY=""

# EXTERNAL AI PROVIDER API KEYS (Optional: If you want to use models other than Gemini for data analysis)
GROQ_API_KEY=""
OPENROUTER_API_KEY=""
